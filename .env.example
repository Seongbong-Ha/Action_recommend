# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=action_recommend
POSTGRES_USER=mobidays
POSTGRES_PASSWORD=mobidays1234

# LLM (mock | real)
LLM_MODE=mock
GEMINI_API_KEY=your_gemini_api_key_here

# Slack 실제 전송 (선택)
# https://api.slack.com/apps 에서 Incoming Webhook 발급
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# STT 화자 분리 (WhisperX 사용 시)
# 1. https://huggingface.co/pyannote/speaker-diarization-3.1 에서 라이선스 동의
# 2. https://huggingface.co/pyannote/segmentation-3.0 에서 라이선스 동의
# 3. https://huggingface.co/settings/tokens 에서 토큰 발급
HUGGINGFACE_TOKEN=your_huggingface_token_here
